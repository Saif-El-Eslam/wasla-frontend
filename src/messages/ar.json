    "footerRights": "\u0642\u0648\u0627\u0626\u0645 Wasla \u0627\u0644\u0639\u0627\u0645\u0629. \u0645\u0628\u0646\u064a\u0629 \u0644\u0627\u0643\u062a\u0634\u0627\u0641 \u0623\u0633\u0631\u0639 \u0644\u0644\u0645\u0646\u0634\u0622\u062a.",
    "backToHome": "\u0627\u0644\u0639\u0648\u062f\u0629 \u0644\u0644\u0631\u0626\u064a\u0633\u064a\u0629",
    "aboutTitle": "\u0639\u0646 Wasla",
    "aboutBody": "\u062a\u0633\u0627\u0639\u062f Wasla \u0627\u0644\u0645\u0646\u0634\u0622\u062a \u0639\u0644\u0649 \u0646\u0634\u0631 \u0642\u0648\u0627\u0626\u0645 \u0639\u0627\u0645\u0629 \u0645\u0631\u062a\u0628\u0629 \u0644\u0643\u0644 \u0641\u0631\u0639\u060c \u0645\u0639 \u0644\u0648\u062d\u0629 \u062a\u062d\u0643\u0645 \u0645\u0631\u0643\u0632\u0629 \u0644\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0642\u0648\u0627\u0626\u0645 \u0648\u0627\u0644\u0640 QR \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644\u0627\u062a.",
    "aboutNote": "\u062a\u0635\u0645\u0645 \u0635\u0641\u062d\u0627\u062a\u0646\u0627 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0636\u064a\u0648\u0641 \u0623\u0648\u0644\u0627: \u062a\u0635\u0641\u062d \u0633\u0631\u064a\u0639\u060c \u0633\u064a\u0627\u0642 \u0648\u0627\u0636\u062d \u0644\u0644\u0641\u0631\u0639\u060c \u0648\u0623\u0632\u0631\u0627\u0631 \u0645\u0628\u0627\u0634\u0631\u0629 \u0644\u0644\u062e\u0631\u0627\u0626\u0637 \u0648\u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0648\u0648\u0627\u062a\u0633\u0627\u0628.",
    "contactTitle": "\u0627\u062a\u0635\u0644 \u0628\u0646\u0627",
    "contactBody": "\u0647\u0644 \u062a\u0631\u064a\u062f \u0625\u0636\u0627\u0641\u0629 \u0645\u0646\u0634\u0623\u062a\u0643\u060c \u0623\u0648 \u0627\u0644\u0633\u0624\u0627\u0644 \u0639\u0646 \u0627\u0644\u062a\u0647\u064a\u0626\u0629\u060c \u0623\u0648 \u0627\u0644\u0625\u0628\u0644\u0627\u063a \u0639\u0646 \u0634\u064a\u0621 \u0641\u064a \u0642\u0627\u0626\u0645\u0629 \u0639\u0627\u0645\u0629\u061f \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639 \u0641\u0631\u064a\u0642 Wasla \u0645\u0646 \u0645\u0633\u0627\u0631 \u0627\u0644\u0644\u0648\u062d\u0629 \u0623\u0648 \u0642\u0646\u0627\u0629 \u0627\u0644\u062a\u0647\u064a\u0626\u0629.",
    "contactNote": "\u062d\u0627\u0644\u064a\u0627 \u064a\u0645\u0643\u0646 \u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u0646\u0634\u0622\u062a \u0627\u0644\u0628\u062f\u0621 \u0628\u0625\u0646\u0634\u0627\u0621 \u062d\u0633\u0627\u0628 \u0648\u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0645\u0646\u0634\u0623\u0629 \u0645\u0646 \u0632\u0631 \u0627\u0644\u062f\u0639\u0648\u0629 \u0641\u064a \u0627\u0644\u0635\u0641\u062d\u0629 \u0627\u0644\u0631\u0626\u064a\u0633\u064a\u0629.",
    "privacyTitle": "\u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629",
